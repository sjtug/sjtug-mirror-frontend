---
import imgSjtug from "@/assets/sjtug.svg";
import { CURRENT_SITE } from "@/config";
---

<footer class="footer">
  <div class="container footer-grid">
    <section class="footer-brand">
      <img src={imgSjtug.src} alt="SJTUG Logo" loading="lazy" />
      <div>
        <p><strong>SJTUG {CURRENT_SITE} Mirror</strong></p>
        <p>由 上海交通大学 Linux 用户组 (SJTUG) 维护</p>
        <p>沪交 ICP 备 20180085</p>
      </div>
    </section>
    <section class="footer-links">
      <a
        class="footer-link"
        href="https://github.com/sjtug/mirror-requests"
        target="_blank"
        rel="noreferrer"
      >
        <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
        反馈 Bug / 提交新镜像请求
      </a>
      <a class="footer-link" href="mailto:sjtug-mirror-maintainers@googlegroups.com">
        <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 7l-10 7L2 7" />
        </svg>
        邮件联系镜像源管理员
      </a>
    </section>
  </div>
</footer>
