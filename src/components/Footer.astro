---
import imgSjtug from "@/assets/sjtug.svg";
import { CURRENT_SITE } from "@/config";
---

<footer>
  <div class="container footer-grid">
    <section class="footer-brand">
      <img src={imgSjtug.src} alt="SJTUG Logo" loading="lazy" />
      <div>
        <p><strong>SJTUG {CURRENT_SITE} Mirror</strong></p>
        <p>由 上海交通大学 Linux 用户组 (SJTUG) 维护</p>
        <p>沪交 ICP 备 20180085</p>
      </div>
    </section>
    <section class="footer-links">
      <div>
        <a
          class="footer-link"
          href="https://github.com/sjtug/mirror-requests"
          target="_blank"
          rel="noreferrer"
        >
          <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 11v.01"></path>
            <path d="M8 11v.01"></path>
            <path d="M16 11v.01"></path>
            <path d="M18 4a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-5l-5 3v-3h-2a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3z"></path>
          </svg>
          反馈 Bug / 提交新镜像请求
        </a>
        <a class="footer-link" href="mailto:sjtug-mirror-maintainers@googlegroups.com">
          <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
            <path d="M3 7l9 6l9 -6"></path>
          </svg>
          邮件联系镜像源管理员
        </a>
      </div>
    </section>
  </div>
</footer>

<style>
footer {
  margin-top: 4rem;
  background: var(--color-footer);
  padding: 4rem 0;
}

.footer-grid {
  display: flex;
  gap: 2rem;
  align-items: center;
  justify-content: center;
}

@media (min-width: 62em) {
  .footer-grid {
    grid-template-columns: minmax(0, 3fr) minmax(0, 1fr);
  }
}

.footer-brand {
  flex: 3;
  display: flex;
  gap: 1rem;
  align-items: center;
  justify-content: center;
}

@media (min-width: 48em) {
  .footer-brand {
    grid-template-columns: minmax(8rem, 12rem) minmax(0, 1fr);
  }
}

.footer-brand img {
  flex: 1;
  width: 100%;
  max-width: 20em;
  height: auto;
}
.footer-brand > div {
  flex: 3;
  min-width: min(100%, 15em);
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.footer-brand p, .footer-links {
  margin: 0;
  font-size: var(--font-size-md);
  line-height: var(--line-height-md);
}

@media (min-width: 48em) {
  .footer-brand p, .footer-links {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-lg);
  }
}

.footer-links {
  flex: 1;
  min-width: min(100%, 10em);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.footer-links > div {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 0.625rem;
}

.footer-link {
  display: inline-flex;
  align-items: center;
}

.footer-icon {
  width: 1.5rem;
  height: 1.5rem;
  flex-shrink: 0;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}
</style>
